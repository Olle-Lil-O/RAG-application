FLYWAY_USER=dbadmin
FLYWAY_PASSWORD=postgres.1
FLYWAY_URL=jdbc:postgresql://paavorei-pgvector.postgres.database.azure.com:5432/postgres?sslmode=require

# Remote Azure PostgreSQL profile
PGHOST=paavorei-pgvector.postgres.database.azure.com
PGUSER=dbadmin
PGPORT=5432
PGDATABASE=postgres
