PGSSLMODE=require

CHUNKER=semantic
CHUNKING_PROVIDER=local
CHUNKING_LOCAL_MODEL=sentence-transformers/all-MiniLM-L6-v2
BREAKPOINT_THRESHOLD_TYPE=percentile
MAX_SENTENCES=5
MAX_EMBED_TOKENS=2000
SPLIT_OVERLAP_TOKENS=80
